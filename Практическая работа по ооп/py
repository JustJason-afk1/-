class Employee:
    def __init__(self, name, position):
        self.name = name
        self.position = position

    def display_info(self):
        print(f"Сотрудник: {self.name}, \n "
              f"Должность: {self.position}")

emp1 = Employee("Колбас", "Человек-Паук")
emp1.display_info()

