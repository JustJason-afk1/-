class Book:
    def __init__(self, name, author, year):
        self.__name = name
        self.author = author
        self.year = year

    def display_info(self):
        print(f"Название: {self.__name}, \n "
              f"Автор: {self.author}, \n "
              f"Год выпуска: {self.year}")

book1 = Book("Души", "Гоголььь", 1842)
book1.display_info()

